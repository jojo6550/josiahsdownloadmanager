{
  "name": "josiahs-download-manager",
  "version": "1.0.0-beta.1",
  "description": "Desktop download manager built with Electron",
  "main": "main.js",
  "bin": {
    "jdm": "./cli.js"
  },
  "scripts": {
    "dl": "node cli.js",
    "test": "node --test \"test/**/*.test.js\""
  },
  "files": [
    "main.js",
    "preload.js",
    "cli.js",
    "src/**/*",
    "renderer/**/*"
  ],
  "build": {
    "appId": "com.josiah.downloadmanager",
    "productName": "Josiah's Download Manager",
    "files": [
      "main.js",
      "preload.js",
      "cli.js",
      "src/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": "AppImage",
      "category": "Network"
    }
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  }
}
